# Higo SPA · Vite + React Router (HashRouter)
# Sirve los archivos reales cuando existen. Sólo reescribe a index.html
# cuando el path solicitado no es un archivo ni carpeta que existe.

# Bloqueo absoluto del diagnóstico Banesco vía HTTP — es CLI-only.
# Defensa en profundidad: el propio script ya hace PHP_SAPI !== 'cli' → 403,
# pero acá cortamos antes de que Apache lo invoque.
<Files "banesco-diagnostic.php">
    Require all denied
</Files>

# Helpers internos de los endpoints API (_cors.php, _ratelimit.php).
# El propio PHP ya devuelve 403 si lo invocan directo (basename check),
# pero cortamos en Apache antes de que se ejecute siquiera.
<FilesMatch "^_.*\.php$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteRule ^index\.html$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-l
    RewriteRule . /index.html [L]
</IfModule>

# MIME types para módulos ES
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType application/javascript .mjs
    AddType text/css .css
    AddType image/svg+xml .svg
</IfModule>

# Compresión
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Cache: como los JS no tienen hash, NO los cacheamos de forma inmutable.
# Sólo fuentes e imágenes (que rara vez cambian y con hash) pueden ser immutables.
<IfModule mod_headers.c>
    <FilesMatch "\.(woff2?|ttf|eot|png|jpg|jpeg|gif)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(js|css|html|svg)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>

    # ── Security headers ──────────────────────────────────────────────
    # Fase 7 paso 1. Meta: securityheaders.com da A o A+.

    # HSTS: 1 año, incluye subdominios. preload requiere submission
    # manual a hstspreload.org — recomendado pero opcional.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # No permitir MIME sniffing — el browser respeta el Content-Type.
    Header always set X-Content-Type-Options "nosniff"

    # Anti-clickjacking. SAMEORIGIN porque Capacitor WebView puede
    # cargar la app en sí misma; DENY rompería el iframe interno.
    Header always set X-Frame-Options "SAMEORIGIN"

    # Referrer: solo origin (no path) cuando se cruza a otro dominio.
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permisos: limitar APIs sensibles a "mi propio origen" — geo/cam/
    # mic se piden desde la app, no desde iframes embebidos.
    Header always set Permissions-Policy "geolocation=(self), camera=(self), microphone=(self), payment=(), usb=(), magnetometer=(), gyroscope=()"

    # Cross-Origin policies (defensa contra Spectre/leaks).
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
    Header always set Cross-Origin-Resource-Policy "same-site"

    # Content Security Policy. Allowlist explícito de los origenes
    # detectados en el bundle (Supabase, Firebase APIs, Gemini, Google
    # Maps) + dolarapi (BCV) + fonts.gstatic (Material Symbols).
    #
    # 'unsafe-inline' en script-src/style-src es necesario por Vite
    # (inyecta inline scripts del runtime) y Tailwind (inyecta inline
    # styles). Tightening con hashes/nonces queda para una fase
    # posterior — no rompe nada hoy.
    Header always set Content-Security-Policy "default-src 'self'; \
script-src 'self' 'unsafe-inline' 'unsafe-eval' https://maps.googleapis.com https://apis.google.com https://www.gstatic.com https://*.googleapis.com; \
style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
font-src 'self' data: https://fonts.gstatic.com; \
img-src 'self' data: blob: https:; \
connect-src 'self' https://*.supabase.co wss://*.supabase.co https://ve.dolarapi.com https://*.googleapis.com https://*.google.com https://securetoken.google.com; \
media-src 'self' blob: data: https://*.supabase.co; \
worker-src 'self' blob:; \
frame-src 'self' https://*.google.com; \
object-src 'none'; \
base-uri 'self'; \
form-action 'self'; \
frame-ancestors 'self';"
</IfModule>
