# Copia este archivo como `.env` y completa los valores.
# NO commitear `.env` (está en .gitignore).
# En producción (GitHub Actions): definir cada variable como secret y
# exportarla como env del job de build (ver .github/workflows/deploy.yml).

# Supabase
VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Google Maps (restringir a higoapp.com + bundle Android com.higoapp.ve)
VITE_GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXX

# Mapbox GL JS — token público restringido por URL/Bundle ID en dashboard Mapbox.
# Solo se usa si VITE_MAP_ENGINE=mapbox.
VITE_MAPBOX_TOKEN=pk.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Motor de mapa visual: 'google' (default, estable) o 'mapbox' (nuevo, Anexo C).
# Permite cutover gradual + rollback sin redeploy de código.
VITE_MAP_ENGINE=google

# Google Gemini
VITE_GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXX

# Firebase Web SDK
VITE_FIREBASE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=YOURPROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOURPROJECT
VITE_FIREBASE_STORAGE_BUCKET=YOURPROJECT.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXX
